#!/usr/bin/env bash
set -euo pipefail

# ============================================================================
# klack — Parallel agentic coding. One command to orchestrate them all.
# ============================================================================

# Find the lib directory (resolves symlinks first)
REAL_BIN="$(readlink -f "$0" 2>/dev/null || python3 -c "import os,sys; print(os.path.realpath(sys.argv[1]))" "$0")"
KLACK_LIB="$(cd "$(dirname "$REAL_BIN")/../lib" && pwd)"
export KLACK_LIB

# --- Dependency Check --------------------------------------------------------

missing=()
for dep in tmux claude; do
  if ! command -v "$dep" &>/dev/null; then
    missing+=("$dep")
  fi
done

if [[ ${#missing[@]} -gt 0 ]]; then
  echo "ERROR: Missing required dependencies: ${missing[*]}" >&2
  echo "Install them and ensure they are in your PATH." >&2
  exit 1
fi

# --- Version -----------------------------------------------------------------

if [[ "${1:-}" == "--version" || "${1:-}" == "-v" || "${1:-}" == "version" ]]; then
  grep '"version"' "$(dirname "$REAL_BIN")/../package.json" | head -1 | sed 's/.*"version": *"\([^"]*\)".*/\1/'
  exit 0
fi

# --- Help --------------------------------------------------------------------

if [[ "${1:-}" == "help" || "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
  cat <<'EOF'
klack — Parallel agentic coding. One command to orchestrate them all.

Commands:
  klack init                          Create .klack.yml in current directory
  klack epic                          Plan an epic interactively (BMAD-Method)
  klack epic <file>                   Plan an epic from a source document
  klack new epic "Name"               Quick-create a local epic
  klack new ticket <epic#> "Name"     Quick-create a local ticket
  klack list                          List local tickets
  klack feat ID [fix ID ...]          Start pipeline for tickets (parallel)
  klack test [scenario]               Run pipeline against test fixture
  klack                               Restore previous session

Options:
  ID+review                           Interactive review after each step
  --force                             Skip interactive reviews (deprecated)

Examples:
  klack epic                          Start interactive epic planning
  klack epic konzept.md               Plan epic from a document
  klack feat E1-001 feat E1-002       Two local tickets in parallel
  klack feat IN-1356+review           Jira ticket with review pauses
  klack feat IN-1356 fix IN-2200      Mixed types, fully autonomous
EOF
  exit 0
fi

# --- Init: Copy .klack.yml.example if no config exists ----------------------

if [[ "${1:-}" == "init" ]]; then
  if [[ -f ".klack.yml" ]]; then
    echo ".klack.yml already exists."
  else
    cp "$KLACK_LIB/../.klack.yml.example" ./.klack.yml
    echo "Created .klack.yml — edit it for your project."
  fi
  exit 0
fi

# --- Epic: Plan epic from source or interactively ----------------------------

if [[ "${1:-}" == "epic" ]]; then
  shift
  source_file="${1:-}"

  KLACK_ROOT="$(pwd)"
  export KLACK_ROOT

  # Sync everything from package
  mkdir -p "$KLACK_ROOT/.claude/commands" "$KLACK_ROOT/.klack/tickets" "$KLACK_ROOT/.klack/scripts/hauptturm"
  cp "$KLACK_LIB/commands/"*.md "$KLACK_ROOT/.claude/commands/"
  cp "$KLACK_LIB/scripts/ticket-run.sh" "$KLACK_ROOT/.klack/scripts/"
  cp "$KLACK_LIB/scripts/hauptturm/"*.sh "$KLACK_ROOT/.klack/scripts/hauptturm/"
  chmod +x "$KLACK_ROOT/.klack/scripts/"*.sh "$KLACK_ROOT/.klack/scripts/hauptturm/"*.sh 2>/dev/null || true

  # Sync BMAD-Method skills if available
  KLACK_SKILLS="$(cd "$(dirname "$REAL_BIN")/../.claude/skills" 2>/dev/null && pwd || echo "")"
  if [[ -z "$KLACK_SKILLS" || ! -d "$KLACK_SKILLS" ]]; then
    echo "Note: Skills directory not found. BMAD-Method skills not bundled — install separately: https://github.com/bmad-code-org/BMAD-METHOD/"
  else
    bmad_found=false
    for d in "$KLACK_SKILLS"/bmad-*; do
      [[ -d "$d" ]] && bmad_found=true && break
    done
    if [[ "$bmad_found" == "true" ]]; then
      mkdir -p "$KLACK_ROOT/.claude/skills"
      cp -r "$KLACK_SKILLS"/bmad-* "$KLACK_ROOT/.claude/skills/" 2>/dev/null || true
    else
      echo "Note: No bmad-* skill directories found in $KLACK_SKILLS. Install BMAD-Method separately: https://github.com/bmad-code-org/BMAD-METHOD/"
    fi
  fi

  export PLAN_PROMPT
  PLAN_PROMPT="$(cat "$KLACK_LIB/commands/klack-plan.md")"

  # Build source context if file provided
  source_context=""
  if [[ -n "$source_file" && -f "$source_file" ]]; then
    source_context="

--- SOURCE DOCUMENT ---
$(cat "$source_file")
--- END SOURCE ---

Das obige Dokument ist die Grundlage fuer das Epic. Nutze es als Input fuer /bmad-create-epics-and-stories."
    echo "Epic planning with source: $source_file"
  fi

  # Write the initial command for the Hauptturm Claude to execute
  mkdir -p "$KLACK_ROOT/.klack"
  cat > "$KLACK_ROOT/.klack/epic-init.md" <<EOPROMPT
${source_context}

Fuehre SOFORT /bmad-create-epics-and-stories aus.
EOPROMPT

  # Start full Klack environment — Hauptturm Claude will pick up epic-init.md
  # We inject into the hauptturm.md system prompt
  HAUPTTURM_CMD="$KLACK_ROOT/.claude/commands/hauptturm.md"
  cat >> "$HAUPTTURM_CMD" <<'EPIC_APPEND'

## Auto-Start

Beim Start: pruefe ob `$KLACK_ROOT/.klack/epic-init.md` existiert. Wenn ja:
1. Lies den Inhalt
2. Fuehre `/bmad-create-epics-and-stories` aus mit dem Kontext aus der Datei
3. Loesche die Datei danach
EPIC_APPEND

  # Start Klack tmux session without tickets (just Hauptturm)
  export KLACK_SESSION="der-klack"

  # Kill stale session
  if tmux has-session -t "$KLACK_SESSION" 2>/dev/null; then
    if ! tmux list-windows -t "$KLACK_SESSION" -F '#{window_name}' 2>/dev/null | grep -qx "hauptturm"; then
      tmux kill-session -t "$KLACK_SESSION" 2>/dev/null
    fi
  fi

  if ! tmux has-session -t "$KLACK_SESSION" 2>/dev/null; then
    tmux new-session -d -s "$KLACK_SESSION" -n "hauptturm" -c "$KLACK_ROOT"
    tmux set-option -t "$KLACK_SESSION" -g mouse on
    tmux set-option -t "$KLACK_SESSION" -g status off
    tmux set-option -t "$KLACK_SESSION" -g pane-border-style "fg=colour240"
    tmux set-option -t "$KLACK_SESSION" -g pane-active-border-style "fg=colour51"
    tmux set-option -t "$KLACK_SESSION" -g pane-border-lines heavy
    tmux set-option -t "$KLACK_SESSION" -g pane-border-format "#{pane_title}"
    tmux set-option -t "$KLACK_SESSION" default-shell "$SHELL"
  fi

  # Init Hauptturm layout
  touch "$KLACK_ROOT/.klack/activity.log"
  export KLACK_ROOT KLACK_SESSION
  bash "$KLACK_ROOT/.klack/scripts/hauptturm/layout.sh" 2>/dev/null || true

  # Send the BMAD epic command to the Claude pane after a delay
  # Find the Claude pane (last one in hauptturm)
  (
    sleep 3
    total=$(tmux list-panes -t "$KLACK_SESSION:hauptturm" 2>/dev/null | wc -l | tr -d ' ')
    claude_pane=$((total - 1))
    tmux send-keys -t "$KLACK_SESSION:hauptturm.$claude_pane" "/bmad-create-epics-and-stories" Enter
  ) &

  exec tmux attach-session -t "$KLACK_SESSION"
fi

# --- New: Create epic + tickets locally (quick, non-interactive) -------------

if [[ "${1:-}" == "new" ]]; then
  shift
  subcommand="${1:-}"
  shift || true

  TICKETS_DIR="$(pwd)/.klack/tickets"
  mkdir -p "$TICKETS_DIR"

  case "$subcommand" in
    epic)
      # Find next epic number
      last_epic=$(find "$TICKETS_DIR" -maxdepth 1 -name 'epic-*.md' 2>/dev/null | sort -V | tail -1 | sed 's/.*epic-\([0-9]*\)\.md/\1/' || echo "0")
      [[ -z "$last_epic" ]] && last_epic=0
      next_epic=$((last_epic + 1))
      epic_file="$TICKETS_DIR/epic-${next_epic}.md"

      title="${*:-Epic $next_epic}"
      cat > "$epic_file" <<EOF
# Epic $next_epic: $title

## Ziel
[Beschreibe das Ziel dieses Epics]

## Tickets
[Werden mit 'klack new ticket $next_epic "Titel"' angelegt]
EOF
      echo "Created: $epic_file"
      echo "Add tickets: klack new ticket $next_epic \"Ticket Titel\""
      ;;

    ticket)
      epic_num="${1:-}"
      shift || true
      title="${*:-Untitled}"

      if [[ -z "$epic_num" ]]; then
        echo "Usage: klack new ticket <epic-number> \"Ticket Titel\"" >&2
        exit 1
      fi

      # Find next ticket number in this epic
      prefix="E${epic_num}"
      last_num=$(find "$TICKETS_DIR" -maxdepth 1 -name "${prefix}-*.md" 2>/dev/null | sort -V | tail -1 | sed "s/.*${prefix}-\([0-9]*\)\.md/\1/" || echo "0")
      [[ -z "$last_num" ]] && last_num=0
      next_num=$(printf "%03d" $((10#$last_num + 1)))
      ticket_id="${prefix}-${next_num}"
      ticket_file="$TICKETS_DIR/${ticket_id}.md"

      cat > "$ticket_file" <<EOF
# ${ticket_id}: $title

Type: feat
Status: open
Depends:

## Beschreibung
[Was gemacht werden soll]

## Acceptance Criteria
- [ ] [Erstes Acceptance Criterion]
EOF
      echo "Created: $ticket_file"
      echo "Run: klack feat $ticket_id"

      # Add to epic file if exists
      epic_file="$TICKETS_DIR/epic-${epic_num}.md"
      if [[ -f "$epic_file" ]]; then
        echo "- ${ticket_id}: $title" >> "$epic_file"
      fi
      ;;

    *)
      echo "Usage:" >&2
      echo "  klack new epic \"Epic Titel\"" >&2
      echo "  klack new ticket <epic-number> \"Ticket Titel\"" >&2
      exit 1
      ;;
  esac
  exit 0
fi

# --- List: Show local tickets ------------------------------------------------

if [[ "${1:-}" == "list" ]]; then
  TICKETS_DIR="$(pwd)/.klack/tickets"
  if [[ ! -d "$TICKETS_DIR" ]]; then
    echo "No local tickets. Create with: klack new epic \"Name\""
    exit 0
  fi

  echo "Epics:"
  for ef in "$TICKETS_DIR"/epic-*.md; do
    [[ -f "$ef" ]] || continue
    head -1 "$ef" | sed 's/^# /  /'
  done

  echo ""
  echo "Tickets:"
  for tf in "$TICKETS_DIR"/E*-*.md; do
    [[ -f "$tf" ]] || continue
    id="$(basename "$tf" .md)"
    title="$(head -1 "$tf" | sed 's/^# //')"
    status="$(grep '^Status:' "$tf" 2>/dev/null | head -1 | sed 's/Status: //' || echo "unknown")"
    printf "  %-12s %-8s %s\n" "$id" "[$status]" "$title"
  done
  exit 0
fi

# --- Test: Run pipeline against Happy API test fixture ----------------------

if [[ "${1:-}" == "test" ]]; then
  shift
  scenario="${1:-default}"

  # Unit tests (no fixture needed)
  if [[ "$scenario" == "unit" ]]; then
    UNIT_DIR="$(dirname "$REAL_BIN")/../test/unit"
    if [[ ! -d "$UNIT_DIR" ]]; then
      echo "ERROR: Unit test directory not found at $UNIT_DIR" >&2
      exit 1
    fi
    echo "Running unit tests..."
    echo ""
    fail=0
    for test_file in "$UNIT_DIR"/*.sh; do
      [[ -f "$test_file" ]] || continue
      echo "--- $(basename "$test_file") ---"
      bash "$test_file" || fail=1
      echo ""
    done
    if [[ $fail -eq 0 ]]; then
      echo "All unit tests passed."
    else
      echo "Some unit tests failed." >&2
      exit 1
    fi
    exit 0
  fi

  # BMad fixture scenario
  if [[ "$scenario" == "bmad" || "$scenario" == "bmad-deps" ]]; then
    FIXTURE_DIR="$(dirname "$REAL_BIN")/../test/fixtures/bmad-api"
    if [[ ! -d "$FIXTURE_DIR" ]]; then
      echo "ERROR: BMad test fixture not found at $FIXTURE_DIR" >&2
      exit 1
    fi

    TEST_DIR="/tmp/klack-test-$(date +%s)"
    echo "Setting up BMad test project in $TEST_DIR..."

    cp -r "$FIXTURE_DIR" "$TEST_DIR"
    cd "$TEST_DIR"

    git init -b main
    git add -A
    git commit -m "init: BMad API test fixture"

    echo "Test project ready: $TEST_DIR"
    echo ""

    if [[ "$scenario" == "bmad" ]]; then
      echo "Running bmad test: feat 1-1 (ticket_source: bmad, find story from _bmad-output/)"
      echo ""
      exec "$REAL_BIN" feat 1-1
    else
      echo "Running bmad-deps test: feat 1-1 feat 1-2 (1-2 depends on 1-1, sequential)"
      echo ""
      exec "$REAL_BIN" feat 1-1 feat 1-2
    fi
  fi

  FIXTURE_DIR="$(dirname "$REAL_BIN")/../test/fixtures/happy-api"
  if [[ ! -d "$FIXTURE_DIR" ]]; then
    echo "ERROR: Test fixture not found at $FIXTURE_DIR" >&2
    exit 1
  fi

  TEST_DIR="/tmp/klack-test-$(date +%s)"
  echo "Setting up test project in $TEST_DIR..."

  cp -r "$FIXTURE_DIR" "$TEST_DIR"
  cd "$TEST_DIR"

  # Install PHP dependencies if composer available
  if command -v composer &>/dev/null; then
    echo "Installing PHP dependencies..."
    composer install --no-interaction --quiet 2>/dev/null || echo "Warning: composer install failed (PHP tools may not work)"
  fi

  # Initialize as git repo
  git init -b main
  git add -A
  git commit -m "init: Happy API test fixture"

  echo "Test project ready: $TEST_DIR"
  echo ""

  case "$scenario" in
    default)
      echo "Running default test: feat E1-001 (Implement /api/happy/{id})"
      echo ""
      exec "$REAL_BIN" feat E1-001
      ;;
    conflict)
      echo "Running conflict test: feat E1-002 feat E1-003 (parallel with shared dependency)"
      echo ""
      exec "$REAL_BIN" feat E1-001 feat E1-002 feat E1-003
      ;;
    review-block)
      echo "Running review-block test: feat E1-004 (triggers security findings)"
      echo ""
      exec "$REAL_BIN" feat E1-001 feat E1-004
      ;;
    all)
      echo "Running all test tickets: E1-001 through E1-004"
      echo ""
      exec "$REAL_BIN" feat E1-001 feat E1-002 feat E1-003 feat E1-004
      ;;
    *)
      echo "Unknown test scenario: $scenario" >&2
      echo "Available: unit, default, conflict, review-block, all, bmad, bmad-deps" >&2
      exit 1
      ;;
  esac
fi

# --- Smart Initialization ---------------------------------------------------

KLACK_ROOT="$(pwd)"
export KLACK_ROOT

if [[ ! -f "$KLACK_ROOT/.klack.yml" ]]; then
  echo ""
  echo "Willkommen bei Klack! Dieses Projekt ist noch nicht initialisiert."
  echo ""
  echo "Welches Ticket-System nutzt du?"
  echo "  1) Jira"
  echo "  2) GitLab"
  echo "  3) GitHub"
  echo "  4) Linear"
  echo "  5) Markdown (lokal)"
  echo ""
  printf "Auswahl [1-5]: "
  read -r ts_choice

  case "$ts_choice" in
    1) ts="jira" ;;
    2) ts="gitlab" ;;
    3) ts="github" ;;
    4) ts="linear" ;;
    5|*) ts="markdown" ;;
  esac

  # Auto-detect PR tool and CI tool from git remote
  pr_tool="github"
  ci_tool="github"
  pr_target="main"
  remote_url="$(git config --get remote.origin.url 2>/dev/null || echo "")"
  if [[ "$remote_url" == *"gitlab"* ]]; then
    pr_tool="gitlab"
    ci_tool="gitlab"
    pr_target="develop"
  fi

  # Extra Jira config
  jira_line=""
  if [[ "$ts" == "jira" ]]; then
    printf "Jira Projekt-Key (z.B. IN, PROJ): "
    read -r jira_key
    [[ -n "$jira_key" ]] && jira_line="jira_project: $jira_key"
  fi

  cat > "$KLACK_ROOT/.klack.yml" <<EOYML
ticket_source: $ts
pr_tool: $pr_tool
pr_target_branch: $pr_target
qa_ci_config: none
ci_tool: $ci_tool
${jira_line}
EOYML

  echo ""
  echo ".klack.yml erstellt (ticket_source: $ts, pr_tool: $pr_tool)"

  # BMAD check
  if [[ ! -d "$KLACK_ROOT/_bmad" ]]; then
    echo "Note: BMAD nicht initialisiert. Fuer volle Pipeline-Unterstuetzung: bmad init oder BMAD-Method Skills installieren."
  fi

  echo ""
  echo "Klack ist bereit! Starte Hauptturm..."
  echo ""
fi

# --- Setup .klack/ runtime directory -----------------------------------------

mkdir -p "$KLACK_ROOT/.klack/scripts/hauptturm"
mkdir -p "$KLACK_ROOT/.klack/signale"

# Sync scripts from package lib to .klack/ (always fresh)
cp "$KLACK_LIB/scripts/ticket-run.sh" "$KLACK_ROOT/.klack/scripts/"
chmod +x "$KLACK_ROOT/.klack/scripts/ticket-run.sh"
cp "$KLACK_LIB/scripts/hauptturm/"*.sh "$KLACK_ROOT/.klack/scripts/hauptturm/"
chmod +x "$KLACK_ROOT/.klack/scripts/hauptturm/"*.sh

# Sync commands to .claude/commands/ (always fresh)
mkdir -p "$KLACK_ROOT/.claude/commands"
cp "$KLACK_LIB/commands/"*.md "$KLACK_ROOT/.claude/commands/"

# Sync skills (all from lib/skills/)
for skill_dir in "$KLACK_LIB/skills"/*/; do
  [[ -d "$skill_dir" ]] || continue
  skill_name="$(basename "$skill_dir")"
  mkdir -p "$KLACK_ROOT/.claude/skills/$skill_name"
  cp "$skill_dir"* "$KLACK_ROOT/.claude/skills/$skill_name/" 2>/dev/null || true
done

# Ensure .gitignore has our entries
GITIGNORE="$KLACK_ROOT/.gitignore"
ENTRIES=(".klack/signale/" ".klack/session.json" ".klack/activity.log" ".klack/active_theme" ".klack/active_ticket" ".klack/cmd.fifo" ".klack/scripts/")
touch "$GITIGNORE"
for entry in "${ENTRIES[@]}"; do
  grep -qxF "$entry" "$GITIGNORE" 2>/dev/null || echo "$entry" >> "$GITIGNORE"
done

# --- Hand off to klack.sh ---------------------------------------------------

exec bash "$KLACK_LIB/scripts/klack.sh" "$@"
